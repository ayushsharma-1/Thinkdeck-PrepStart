# Copy this file to .env and fill in your API keys and configurations

# AI Services (Required - Get from respective providers)
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here
GROQ_API_KEY=your_groq_api_key_here  
GOOGLE_API_KEY=your_google_ai_api_key_here

# Database & Message Queue (Cloud services for production)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/prepstart
RABBITMQ_URL=amqps://username:password@host.cloudamqp.com/username

# Redis Configuration (Cloud Redis for production)
REDIS_URL=redis://username:password@host:port
REDIS_PASSWORD=your_redis_password_here

# Service URLs (Local development)
FASTAPI_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_FASTAPI_URL=http://localhost:8000

# Environment Configuration
NODE_ENV=development
PYTHON_ENV=development

# Server Configuration
PORT=3000
HOST=0.0.0.0

# AI Model Configuration
GROQ_MODEL=llama-3.1-8b-instant
GOOGLE_MODEL=gemini-1.5-flash

# Session Configuration
SESSION_TIMEOUT=1800
INTERVIEW_DURATION=1800

# CORS Configuration
CORS_ORIGINS=http://localhost:3001,http://localhost:3000
CORS_ORIGIN=http://localhost:3001,http://localhost:3000

# WebRTC Configuration
NEXT_PUBLIC_ENABLE_WEBRTC=true
NEXT_PUBLIC_ENABLE_SCREEN_SHARE=true

# UI Configuration
NEXT_PUBLIC_APP_NAME=PrepStart AI Interview
NEXT_PUBLIC_APP_VERSION=2.0.0
