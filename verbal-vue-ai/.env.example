# ==============================================
# Verbal Vue AI - Frontend Environment Variables
# ==============================================

# API Configuration
VITE_API_BASE_URL=http://localhost:8000/api
VITE_WEBSOCKET_URL=ws://localhost:8000

# Production URLs (uncomment for production)
# VITE_API_BASE_URL=https://api.verbalvue.ai/api
# VITE_WEBSOCKET_URL=wss://api.verbalvue.ai

# Upload Configuration
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.txt,.rtf
VITE_UPLOAD_ENDPOINT=/upload

# Feature Flags
VITE_ENABLE_MOCK_INTERVIEWS=true
VITE_ENABLE_CODE_EXECUTION=true
VITE_ENABLE_MCQ_TESTS=true
VITE_ENABLE_FILE_UPLOAD=true
VITE_ENABLE_AUDIO_RECORDING=true
VITE_ENABLE_REAL_TIME_FEATURES=true

# Audio/Video Configuration
VITE_AUDIO_RECORDING_FORMAT=webm
VITE_AUDIO_BITRATE=128000
VITE_RECORDING_MAX_DURATION=300000
VITE_AUDIO_CHUNK_SIZE=4096

# Code Editor Configuration
VITE_DEFAULT_LANGUAGE=python
VITE_SUPPORTED_LANGUAGES=python,javascript,java,cpp,c,go,rust,typescript
VITE_CODE_EXECUTION_TIMEOUT=60000
VITE_EDITOR_THEME=vs-dark

# MCQ Test Configuration
VITE_DEFAULT_MCQ_TIME_LIMIT=1200
VITE_MIN_QUESTIONS_PER_TEST=5
VITE_MAX_QUESTIONS_PER_TEST=50
VITE_AUTO_SUBMIT_ON_TIMEOUT=true

# Interview Configuration
VITE_INTERVIEW_MAX_DURATION=3600
VITE_QUESTIONS_PER_INTERVIEW=5
VITE_ENABLE_PRACTICE_MODE=true
VITE_TRANSCRIPTION_CONFIDENCE_THRESHOLD=0.8

# UI/UX Configuration
VITE_APP_TITLE="Verbal Vue AI"
VITE_APP_DESCRIPTION="AI-Powered Coding Assessment & Mock Interview Platform"
VITE_THEME_COLOR=#3b82f6
VITE_DEFAULT_THEME=light
VITE_ENABLE_DARK_MODE=true

# Performance Configuration
VITE_API_TIMEOUT=30000
VITE_RETRY_ATTEMPTS=3
VITE_RETRY_DELAY=1000
VITE_DEBOUNCE_DELAY=300
VITE_PAGINATION_SIZE=20

# Analytics & Monitoring
VITE_ENABLE_ANALYTICS=false
VITE_GOOGLE_ANALYTICS_ID=
VITE_SENTRY_DSN=
VITE_ENABLE_ERROR_REPORTING=true

# Development & Debugging
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=info
VITE_SHOW_DEV_TOOLS=false
VITE_MOCK_API_CALLS=false
VITE_ENABLE_HOT_RELOAD=true

# Social & Branding
VITE_COMPANY_NAME="Verbal Vue AI"
VITE_SUPPORT_EMAIL=support@verbalvue.ai
VITE_WEBSITE_URL=https://verbalvue.ai
VITE_GITHUB_URL=https://github.com/ayushsharma-1/verbal-vue-ai

# Security Configuration
VITE_ENABLE_CSP=true
VITE_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
VITE_SESSION_TIMEOUT=1800000
VITE_AUTO_LOGOUT_WARNING=300000

# Notification Configuration
VITE_ENABLE_NOTIFICATIONS=true
VITE_NOTIFICATION_DURATION=5000
VITE_ENABLE_SOUND_NOTIFICATIONS=false
VITE_MAX_NOTIFICATIONS=5

# Accessibility Configuration
VITE_ENABLE_A11Y=true
VITE_HIGH_CONTRAST_MODE=false
VITE_FONT_SIZE_MULTIPLIER=1
VITE_ENABLE_KEYBOARD_SHORTCUTS=true

# Internationalization
VITE_DEFAULT_LOCALE=en
VITE_SUPPORTED_LOCALES=en,es,fr,de,hi
VITE_ENABLE_RTL=false

# Cache Configuration
VITE_ENABLE_SERVICE_WORKER=true
VITE_CACHE_API_RESPONSES=true
VITE_CACHE_DURATION=300000
VITE_OFFLINE_SUPPORT=false

# Build Configuration
VITE_BUILD_VERSION=1.0.0
VITE_BUILD_DATE=2025-01-08
VITE_ENVIRONMENT=development
VITE_PUBLIC_PATH=/

# Third-party Integrations
VITE_ENABLE_GOOGLE_FONTS=true
VITE_CDN_URL=
VITE_ENABLE_EXTERNAL_SCRIPTS=false

# Progressive Web App
VITE_ENABLE_PWA=true
VITE_PWA_NAME="Verbal Vue AI"
VITE_PWA_SHORT_NAME="VerbVue"
VITE_PWA_THEME_COLOR=#3b82f6
VITE_PWA_BACKGROUND_COLOR=#ffffff

# ==============================================
# Development Override (for local development)
# ==============================================

# Uncomment these for development with different ports
# VITE_API_BASE_URL=http://localhost:3001/api
# VITE_WEBSOCKET_URL=ws://localhost:3001

# Uncomment for backend running in Docker
# VITE_API_BASE_URL=http://localhost:8000/api
# VITE_WEBSOCKET_URL=ws://localhost:8000

# ==============================================
# Production Override (for production build)
# ==============================================

# Set these for production deployment
# VITE_DEBUG_MODE=false
# VITE_LOG_LEVEL=error
# VITE_ENABLE_ANALYTICS=true
# VITE_MOCK_API_CALLS=false
# VITE_ENVIRONMENT=production
